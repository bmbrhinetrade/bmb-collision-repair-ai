# Required for AI vision estimate generation
OPENAI_API_KEY=

# Optional: main estimate model (highest quality, higher cost)
OPENAI_VISION_MODEL=gpt-4.1
# Optional: cheaper OCR models for license + door-jamb extraction
OPENAI_LICENSE_MODEL=gpt-4.1-mini
OPENAI_DOOR_LABEL_MODEL=gpt-4.1-mini
# Optional: cap extraction response tokens to reduce cost
OPENAI_LICENSE_MAX_OUTPUT_TOKENS=220
OPENAI_DOOR_LABEL_MAX_OUTPUT_TOKENS=260
# Optional: cache extraction results for repeated uploads of same image
EXTRACTION_CACHE_TTL_SECONDS=86400
EXTRACTION_CACHE_MAX_ITEMS=300

# Optional VIN provider for data beyond NHTSA (paint code, deeper build data)
VIN_EXTRA_PROVIDER_URL=
VIN_EXTRA_PROVIDER_TOKEN=

# Optional OEM dealership parts provider
# Expected request: POST JSON with vehicle + components[] and return items[] with
# component, partNumber, description, quantity, listPrice (and optional lineTotal/subtotal)
OEM_PARTS_PROVIDER_URL=
OEM_PARTS_PROVIDER_TOKEN=

# Optional app port
PORT=3000
# Optional host binding (set 127.0.0.1 for local-only)
HOST=0.0.0.0

# Optional supplement logo override (defaults to bmbrhinetradeinc.com logo asset)
# BMB_LOGO_URL=https://framerusercontent.com/images/mYEOmnUYBqG1jUuiKqIAFXijrIM.png?height=926&width=2828
# Optional local logo file path relative to project root
# BMB_LOGO_FILE=assets/bmb-logo.png
